{% extends "layout/masterLayout.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <h1 class="page-title">Manajemen Pengguna</h1>
    <p class="page-subtitle">Kelola akun dan hak akses pengguna sistem</p>
  </div>
  <div class="d-flex gap-2 flex-wrap">
    <button class="btn btn-outline-secondary btn-sm" id="btnDownloadData"><i class="fas fa-file-excel"></i> Export</button>
    <button class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#uploadModal"><i class="fas fa-upload"></i> Import</button>
    <button class="btn btn-outline-secondary btn-sm" id="btnDownloadTemplate"><i class="fas fa-download"></i> Template</button>
    <a href="/auth/register" class="btn btn-primary btn-sm"><i class="fas fa-user-plus"></i> Tambah Pengguna</a>
  </div>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
  <div class="col-sm-4">
    <div class="card stat-card stat-accent-blue">
      <div class="card-body" style="padding:.875rem 1rem;">
        <div class="stat-icon"><i class="fas fa-users"></i></div>
        <div class="stat-label">Total Pengguna</div>
        <div class="stat-value mt-1" style="font-size:1.4rem;">{{ users.length }}</div>
      </div>
    </div>
  </div>
  <div class="col-sm-4">
    <div class="card stat-card stat-accent-green">
      <div class="card-body" style="padding:.875rem 1rem;">
        <div class="stat-icon"><i class="fas fa-user-shield"></i></div>
        <div class="stat-label">Admin</div>
        <div class="stat-value mt-1" style="font-size:1.4rem;">{{ users | selectattr('role', 'equalto', 'Admin') | list | length }}</div>
      </div>
    </div>
  </div>
  <div class="col-sm-4">
    <div class="card stat-card stat-accent-amber">
      <div class="card-body" style="padding:.875rem 1rem;">
        <div class="stat-icon"><i class="fas fa-user-check"></i></div>
        <div class="stat-label">Manager</div>
        <div class="stat-value mt-1" style="font-size:1.4rem;">{{ users | selectattr('role', 'equalto', 'Manager') | list | length }}</div>
      </div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header"><h6 class="card-header-title"><i class="fas fa-users-cog"></i> Daftar Pengguna</h6></div>
  <div class="card-body">
    <div class="table-responsive">
      <table id="datatablesSimple" class="table">
        <thead>
          <tr><th>ID</th><th>Pengguna</th><th>Email</th><th>Role</th><th>Dibuat</th><th>Aksi</th></tr>
        </thead>
        <tbody>
          {% for u in users %}
          <tr>
            <td style="color:var(--text-3);font-size:.75rem;">{{ u.id }}</td>
            <td>
              <div class="d-flex align-items-center gap-2">
                <div class="user-avatar avatar-blue" style="width:28px;height:28px;font-size:.7rem;">{{ u.username[0] | upper }}</div>
                <span style="font-weight:500;">{{ u.username }}</span>
              </div>
            </td>
            <td style="color:var(--text-2);">{{ u.email }}</td>
            <td>
              {% if u.role == 'Admin' %}<span class="badge bg-danger">Admin</span>
              {% elif u.role == 'Manager' %}<span class="badge bg-warning">Manager</span>
              {% else %}<span class="badge bg-secondary">{{ u.role }}</span>{% endif %}
            </td>
            <td style="font-size:.775rem;color:var(--text-3);">{{ u.created_at if u.created_at else '—' }}</td>
            <td>
              <div class="d-flex gap-1">
                <button class="btn btn-outline-secondary btn-sm btn-edit"
                  data-bs-toggle="modal" data-bs-target="#editModal"
                  data-id="{{ u.id }}" data-username="{{ u.username }}" data-email="{{ u.email }}" data-role="{{ u.role }}">
                  <i class="fas fa-pencil-alt"></i>
                </button>
                <button class="btn btn-outline-danger btn-sm delete-btn" data-id="{{ u.id }}" data-nama="{{ u.username }}">
                  <i class="fas fa-trash-alt"></i>
                </button>
              </div>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Modal Upload -->
<div class="modal fade" id="uploadModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header">
      <h5 class="modal-title"><i class="fas fa-upload" style="color:var(--accent)"></i> Import Pengguna</h5>
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <form enctype="multipart/form-data" method="post" action="/user/upload">
      <div class="modal-body">
        <div class="alert alert-info"><i class="fas fa-info-circle flex-shrink-0"></i><span>File Excel (.xlsx/.xls). Download template untuk format yang benar.</span></div>
        <label class="form-label">Pilih file Excel</label>
        <input type="file" class="form-control" name="fileUpload" accept=".xls,.xlsx" required>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Batal</button>
        <button type="submit" class="btn btn-primary"><i class="fas fa-upload"></i> Upload</button>
      </div>
    </form>
  </div></div>
</div>

<!-- Modal Edit -->
<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header">
      <h5 class="modal-title"><i class="fas fa-pencil-alt" style="color:var(--accent)"></i> Edit Pengguna</h5>
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <form method="POST" action="/user/update">
      <div class="modal-body">
        <input type="hidden" id="editId" name="id">
        <div class="row g-3">
          <div class="col-12"><label class="form-label">Username</label><input type="text" class="form-control" id="editUsername" name="username" required></div>
          <div class="col-12"><label class="form-label">Email</label><input type="email" class="form-control" id="editEmail" name="email" required></div>
          <div class="col-12"><label class="form-label">Role</label>
            <select class="form-select" id="editRole" name="role">
              <option value="Admin">Admin</option>
              <option value="Manager">Manager</option>
              <option value="User">User</option>
            </select>
          </div>
          <div class="col-12"><label class="form-label">Password Baru <span style="color:var(--text-3);font-weight:400;">(kosongkan jika tidak diubah)</span></label><input type="password" class="form-control" name="password" autocomplete="new-password"></div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Batal</button>
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Simpan Perubahan</button>
      </div>
    </form>
  </div></div>
</div>

<!-- Modal Hapus -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-sm"><div class="modal-content">
    <div class="modal-header">
      <h5 class="modal-title"><i class="fas fa-exclamation-triangle" style="color:var(--danger)"></i> Hapus Pengguna</h5>
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <div class="modal-body text-center" style="padding:1.5rem;">
      <p style="color:var(--text-2);font-size:.875rem;">Yakin ingin menghapus pengguna</p>
      <p style="font-weight:600;color:var(--danger);" id="deleteItemName"></p>
    </div>
    <div class="modal-footer">
      <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Batal</button>
      <form id="deleteForm" method="POST" class="d-inline">
        <button type="submit" class="btn btn-danger"><i class="fas fa-trash-alt"></i> Hapus</button>
      </form>
    </div>
  </div></div>
</div>
{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
  if (typeof simpleDatatables !== 'undefined') new simpleDatatables.DataTable('#datatablesSimple');
  document.querySelectorAll('.btn-edit').forEach(btn => {
    btn.addEventListener('click', function() {
      document.getElementById('editId').value       = this.dataset.id;
      document.getElementById('editUsername').value = this.dataset.username;
      document.getElementById('editEmail').value    = this.dataset.email;
      document.getElementById('editRole').value     = this.dataset.role;
    });
  });
  document.querySelectorAll('.delete-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      document.getElementById('deleteItemName').textContent = this.dataset.nama;
      document.getElementById('deleteForm').action = '/user/hapus/' + this.dataset.id;
      new bootstrap.Modal(document.getElementById('deleteModal')).show();
    });
  });
  document.getElementById('btnDownloadData')?.addEventListener('click', () => window.location.href='/user/download');
  document.getElementById('btnDownloadTemplate')?.addEventListener('click', () => window.location.href='/user/template');
});
</script>
{% endblock %}
