{% extends "layout/masterLayout.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <h1 class="page-title">Dashboard</h1>
    <p class="page-subtitle">Ringkasan operasional hari ini</p>
  </div>
  <div class="d-flex align-items-center gap-2">
    <span class="live-dot"></span>
    <span style="font-size:.75rem; color:var(--text-3)" id="currentDateTime">—</span>
    <button class="btn btn-outline-secondary btn-sm" onclick="dashboardPOS.loadInitialData()" id="refreshBtn">
      <i class="fas fa-sync-alt"></i> Refresh
    </button>
  </div>
</div>

<!-- KPI Cards -->
<div class="row g-3 mb-4">
  <div class="col-xl-3 col-sm-6">
    <div class="card stat-card stat-accent-blue">
      <div class="card-body" style="padding:1.125rem 1.125rem 1rem;">
        <div class="stat-icon"><i class="fas fa-money-bill-wave"></i></div>
        <div class="stat-label">Penjualan Hari Ini</div>
        <div class="stat-value mt-1" id="todaySales"><div class="loading-shimmer" style="height:28px;width:120px;"></div></div>
        <div class="stat-sub" id="todayTransactionCount">— transaksi</div>
        <a href="/transaksi/laporan_penjualan" class="btn btn-outline-primary btn-sm mt-3">
          <i class="fas fa-chart-line"></i> Detail
        </a>
      </div>
    </div>
  </div>
  <div class="col-xl-3 col-sm-6">
    <div class="card stat-card stat-accent-green">
      <div class="card-body" style="padding:1.125rem 1.125rem 1rem;">
        <div class="stat-icon"><i class="fas fa-boxes"></i></div>
        <div class="stat-label">Total Barang</div>
        <div class="stat-value mt-1" id="totalProducts"><div class="loading-shimmer" style="height:28px;width:80px;"></div></div>
        <div class="stat-sub" id="totalStock">— unit stok</div>
        <a href="/stok/index" class="btn btn-sm mt-3" style="border:1px solid var(--success);color:var(--success);border-radius:var(--radius-sm);padding:.3rem .75rem;font-size:.775rem;">
          <i class="fas fa-cog"></i> Kelola
        </a>
      </div>
    </div>
  </div>
  <div class="col-xl-3 col-sm-6">
    <div class="card stat-card stat-accent-amber">
      <div class="card-body" style="padding:1.125rem 1.125rem 1rem;">
        <div class="stat-icon"><i class="fas fa-exclamation-triangle"></i></div>
        <div class="stat-label">Stok Menipis</div>
        <div class="stat-value mt-1" id="lowStock"><div class="loading-shimmer" style="height:28px;width:60px;"></div></div>
        <div class="stat-sub">Perlu restock segera</div>
        <a href="/stok/index" class="btn btn-sm mt-3" style="border:1px solid var(--warning);color:var(--warning);border-radius:var(--radius-sm);padding:.3rem .75rem;font-size:.775rem;">
          <i class="fas fa-eye"></i> Cek
        </a>
      </div>
    </div>
  </div>
  <div class="col-xl-3 col-sm-6">
    <div class="card stat-card stat-accent-cyan">
      <div class="card-body" style="padding:1.125rem 1.125rem 1rem;">
        <div class="stat-icon"><i class="fas fa-users"></i></div>
        <div class="stat-label">Total Pelanggan</div>
        <div class="stat-value mt-1" id="totalCustomers"><div class="loading-shimmer" style="height:28px;width:80px;"></div></div>
        <div class="stat-sub">Terdaftar di sistem</div>
        <a href="/customer/index" class="btn btn-sm mt-3" style="border:1px solid var(--info);color:var(--info);border-radius:var(--radius-sm);padding:.3rem .75rem;font-size:.775rem;">
          <i class="fas fa-user-plus"></i> Kelola
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Quick Actions -->
<div class="card mb-4">
  <div class="card-header">
    <h6 class="card-header-title"><i class="fas fa-bolt"></i> Aksi Cepat</h6>
  </div>
  <div class="card-body">
    <div class="row g-2">
      <div class="col-lg-2 col-md-4 col-6">
        <a href="/transaksi/pos" class="quick-btn" style="border-color:var(--success);color:var(--success);">
          <i class="fas fa-cash-register"></i>
          <span>Transaksi Baru</span>
        </a>
      </div>
      <div class="col-lg-2 col-md-4 col-6">
        <a href="/stok/index" class="quick-btn">
          <i class="fas fa-plus-square"></i>
          <span>Tambah Barang</span>
        </a>
      </div>
      <div class="col-lg-2 col-md-4 col-6">
        <a href="/pembelian/baru" class="quick-btn">
          <i class="fas fa-truck"></i>
          <span>Pembelian</span>
        </a>
      </div>
      <div class="col-lg-2 col-md-4 col-6">
        <a href="/customer/index" class="quick-btn">
          <i class="fas fa-user-plus"></i>
          <span>Pelanggan</span>
        </a>
      </div>
      <div class="col-lg-2 col-md-4 col-6">
        <a href="/transaksi/laporan_penjualan" class="quick-btn">
          <i class="fas fa-chart-bar"></i>
          <span>Laporan</span>
        </a>
      </div>
      <div class="col-lg-2 col-md-4 col-6">
        <a href="/retur/baru" class="quick-btn" style="border-color:var(--danger);color:var(--danger);">
          <i class="fas fa-undo-alt"></i>
          <span>Retur</span>
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Charts Row -->
<div class="row g-3 mb-4">
  <div class="col-xl-8">
    <div class="card">
      <div class="card-header">
        <h6 class="card-header-title"><i class="fas fa-chart-area"></i> Grafik Penjualan 7 Hari Terakhir</h6>
      </div>
      <div class="card-body">
        <div style="position:relative;height:280px;">
          <canvas id="salesChart"></canvas>
          <div id="chartLoadingOverlay" class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-white" style="display:none!important;">
            <div class="text-center">
              <div class="spinner-border text-primary" role="status" style="width:1.5rem;height:1.5rem;"></div>
              <div class="mt-2" style="font-size:.75rem;color:var(--text-3);">Memuat grafik…</div>
            </div>
          </div>
          <div id="chartErrorState" class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center" style="display:none!important;background:var(--surface-2);">
            <div class="text-center" style="color:var(--text-3);">
              <i class="fas fa-chart-area mb-2" style="font-size:2rem;opacity:.4;display:block;"></i>
              <small>Gagal memuat grafik</small>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-xl-4">
    <div class="card">
      <div class="card-header">
        <h6 class="card-header-title"><i class="fas fa-star"></i> Produk Terlaris</h6>
      </div>
      <div class="card-body" id="topProductsContainer" style="padding:.75rem 1.125rem;">
        <div class="loading-shimmer" style="height:14px;margin-bottom:10px;"></div>
        <div class="loading-shimmer" style="height:14px;margin-bottom:10px;width:80%;"></div>
        <div class="loading-shimmer" style="height:14px;margin-bottom:10px;width:90%;"></div>
        <div class="loading-shimmer" style="height:14px;width:70%;"></div>
      </div>
    </div>
  </div>
</div>

<!-- Recent Transactions -->
<div class="card mb-2">
  <div class="card-header">
    <h6 class="card-header-title"><i class="fas fa-receipt"></i> Transaksi Terbaru</h6>
    <a href="/transaksi/index" class="btn btn-ghost btn-sm" style="font-size:.775rem;">Lihat Semua <i class="fas fa-arrow-right ms-1"></i></a>
  </div>
  <div id="recentTransactionsContainer">
    <div class="card-body">
      <div class="loading-shimmer" style="height:40px;margin-bottom:8px;"></div>
      <div class="loading-shimmer" style="height:40px;margin-bottom:8px;"></div>
      <div class="loading-shimmer" style="height:40px;"></div>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script>
const dashboardPOS = {
  salesChart: null,

  async loadInitialData() {
    const refreshBtn = document.getElementById('refreshBtn');
    if (refreshBtn) { refreshBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>'; refreshBtn.disabled = true; }
    try {
      const res = await fetch('/api/dashboard', { headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' } });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const result = await res.json();
      if (!result.success) throw new Error(result.message || 'Gagal memuat data');
      const d = result.data;
      // Stats
      const fmt = n => 'Rp ' + Number(n||0).toLocaleString('id-ID');
      document.getElementById('todaySales').textContent            = fmt(d.todaySales);
      document.getElementById('todayTransactionCount').textContent = (d.todayTransactionCount||0) + ' transaksi';
      document.getElementById('totalProducts').textContent         = (d.totalProducts||0).toLocaleString('id-ID') + ' produk';
      document.getElementById('totalStock').textContent            = (d.totalStock||0).toLocaleString('id-ID') + ' unit stok';
      document.getElementById('lowStock').textContent              = (d.lowStockCount||0).toLocaleString('id-ID');
      document.getElementById('totalCustomers').textContent        = (d.totalCustomers||0).toLocaleString('id-ID');
      // Chart
      if (d.salesChart && d.salesChart.length) this.updateSalesChart(d.salesChart);
      // Top products
      if (d.topProducts) this.updateTopProducts(d.topProducts);
      // Recent transactions
      if (d.recentTransactions) this.updateRecentTransactions(d.recentTransactions);
    } catch(e) {
      console.error('Dashboard error:', e);
      ['todaySales','totalProducts','lowStock','totalCustomers'].forEach(id => {
        const el = document.getElementById(id); if (el) el.textContent = '—';
      });
    }
    if (refreshBtn) { refreshBtn.innerHTML = '<i class="fas fa-sync-alt"></i> Refresh'; refreshBtn.disabled = false; }
  },

  updateSalesChart(salesData) {
    const ctx = document.getElementById('salesChart').getContext('2d');
    if (this.salesChart) this.salesChart.destroy();
    this.salesChart = new Chart(ctx, {
      type: 'line',
      data: {
        labels: salesData.map(i => i.formatted_date || i.date || i.tanggal),
        datasets: [
          {
            label: 'Penjualan',
            data: salesData.map(i => parseFloat(i.daily_sales||i.total||0)),
            borderColor: '#2563EB', backgroundColor: 'rgba(37,99,235,.07)',
            borderWidth: 2, pointRadius: 3, tension: .4, fill: true, yAxisID: 'y'
          },
          {
            label: 'Transaksi',
            data: salesData.map(i => parseInt(i.transaction_count||0)),
            borderColor: '#059669', backgroundColor: 'transparent',
            borderWidth: 2, pointRadius: 3, tension: .4, fill: false, yAxisID: 'y1'
          }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: true, position: 'top', labels: { font: { size: 11 } } },
          tooltip: { callbacks: { label: c => c.datasetIndex === 0 ? 'Rp ' + Number(c.raw).toLocaleString('id-ID') : c.raw + ' transaksi' }}
        },
        scales: {
          x: { grid: { display: false }, ticks: { font: { size: 11 }, color: '#94A3B8' } },
          y: { position: 'left', grid: { color: '#F1F5F9' }, beginAtZero: true,
               ticks: { font: { size: 10 }, color: '#94A3B8', callback: v => v >= 1e6 ? (v/1e6).toFixed(1)+'jt' : v >= 1e3 ? (v/1e3).toFixed(0)+'rb' : v }},
          y1: { position: 'right', grid: { display: false }, beginAtZero: true,
                ticks: { font: { size: 10 }, color: '#94A3B8' }}
        }
      }
    });
  },

  updateTopProducts(products) {
    const container = document.getElementById('topProductsContainer');
    if (!products || !products.length) {
      container.innerHTML = '<p style="color:var(--text-3);font-size:.8rem;text-align:center;padding:1rem">Belum ada data</p>';
      return;
    }
    container.innerHTML = products.slice(0,5).map((p, i) => `
      <div style="display:flex;align-items:center;gap:.75rem;padding:.5rem 0;border-bottom:1px solid var(--border);">
        <span style="width:20px;height:20px;border-radius:50%;background:var(--accent-light);color:var(--accent);font-size:.7rem;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0;">${i+1}</span>
        <div style="flex:1;min-width:0;">
          <div style="font-size:.8rem;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${p.nama||p.name||p.product_name||'—'}</div>
          <div style="font-size:.72rem;color:var(--text-3);">${p.total_terjual||p.sold||p.qty||0} terjual</div>
        </div>
        <span style="font-size:.78rem;font-weight:600;color:var(--text-1);">Rp ${Number(p.total_pendapatan||p.revenue||p.total||0).toLocaleString('id-ID')}</span>
      </div>`).join('');
  },

  updateRecentTransactions(transactions) {
    const container = document.getElementById('recentTransactionsContainer');
    if (!transactions || !transactions.length) {
      container.innerHTML = '<div class="card-body" style="text-align:center;color:var(--text-3);font-size:.8rem;">Belum ada transaksi</div>';
      return;
    }
    container.innerHTML = `<div class="table-responsive"><table class="table mb-0">
      <thead><tr><th>ID</th><th>Pelanggan</th><th>Total</th><th>Metode</th><th>Waktu</th></tr></thead>
      <tbody>${transactions.map(t => `
        <tr>
          <td><code style="font-size:.75rem;">#${t.id||'—'}</code></td>
          <td>${t.customer_name||t.customer_nama||'Walk-in'}</td>
          <td style="font-weight:600;">Rp ${Number(t.total_harga||0).toLocaleString('id-ID')}</td>
          <td><span class="badge bg-secondary">${t.payment_method||t.metode_pembayaran||'—'}</span></td>
          <td style="color:var(--text-3);font-size:.775rem;">${t.tanggal_transaksi||t.created_at||'—'}</td>
        </tr>`).join('')}
      </tbody></table></div>`;
  }
};

document.addEventListener('DOMContentLoaded', () => {
  const updateTime = () => {
    const el = document.getElementById('currentDateTime');
    if (el) el.textContent = new Date().toLocaleString('id-ID', { weekday:'short',day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit' });
  };
  updateTime(); setInterval(updateTime, 60000);
  dashboardPOS.loadInitialData();
});
</script>
{% endblock %}
