{% block scripts %}
    <script>
        // Improved Dashboard Class Implementation
        class DashboardPOS {
            constructor(options = {}) {
                this.config = {
                    refreshInterval: options.refreshInterval || 5 * 60 * 1000,
                    lowStockThreshold: options.lowStockThreshold || 15,
                    animationDuration: options.animationDuration || 1000,
                    maxRetries: options.maxRetries || 3,
                    retryDelay: options.retryDelay || 2000,
                    ...options
                };
                
                this.chartInstance = null;
                this.isLoading = false;
                this.refreshTimer = null;
                this.retryCount = 0;
                this.abortController = null;
                
                this.init();
            }

            init() {
                this.loadInitialData();
                this.setupEventListeners();
                this.setupAutoRefresh();
                this.updateSystemTime();
                this.monitorConnectionStatus();
                
                window.addEventListener('beforeunload', () => this.cleanup());
            }

            showLoadingState() {
                this.isLoading = true;
                const overlay = document.getElementById('loadingOverlay');
                const refreshBtn = document.getElementById('refreshBtn');
                
                if (overlay) overlay.classList.add('show');
                if (refreshBtn) {
                    refreshBtn.disabled = true;
                    refreshBtn.innerHTML = '<i class="bi bi-arrow-clockwise spin"></i> Loading...';
                }
            }

            hideLoadingState() {
                this.isLoading = false;
                const overlay = document.getElementById('loadingOverlay');
                const refreshBtn = document.getElementById('refreshBtn');
                
                if (overlay) overlay.classList.remove('show');
                if (refreshBtn) {
                    refreshBtn.disabled = false;
                    refreshBtn.innerHTML = '<i class="bi bi-arrow-clockwise"></i> Refresh';
                }
            }

            async loadInitialData() {
                if (this.isLoading) return;
                
                try {
                    this.showLoadingState();
                    
                    if (this.abortController) {
                        this.abortController.abort();
                    }
                    
                    this.abortController = new AbortController();
                    
                    const response = await fetch('/api/dashboard', {
                        signal: this.abortController.signal,
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });
                    
                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                    }
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        this.updateDashboard(result.data);
                        this.showToast('Dashboard berhasil dimuat', 'success');
                        this.retryCount = 0;
                    } else {
                        throw new Error(result.message || 'Failed to load dashboard data');
                    }
                } catch (error) {
                    if (error.name === 'AbortError') {
                        console.log('Request was cancelled');
                        return;
                    }
                    
                    console.error('Error loading dashboard:', error);
                    
                    if (this.retryCount < this.config.maxRetries) {
                        this.retryCount++;
                        this.showToast(`Mencoba ulang... (${this.retryCount}/${this.config.maxRetries})`, 'warning');
                        
                        setTimeout(() => {
                            this.loadInitialData();
                        }, this.config.retryDelay * this.retryCount);
                        
                        return;
                    }
                    
                    this.showToast('Gagal memuat data dashboard. Menggunakan data fallback.', 'error');
                    this.loadFallbackData();
                } finally {
                    this.hideLoadingState();
                    this.abortController = null;
                }
            }

            updateDashboard(data) {
                this.updateMetricCards(data);
                this.updateSalesChart(data.salesChart);
                this.updateTopProducts(data.topProducts);
                this.updateRecentTransactions(data.recentTransactions);
                this.updateLowStockItems(data.lowStockItems);
                this.updateLastUpdateTime(data.lastUpdated);
            }

            updateMetricCards(data) {
                // Today Sales
                const todaySalesEl = document.getElementById('todaySales');
                if (todaySalesEl) {
                    todaySalesEl.innerHTML = new Intl.NumberFormat('id-ID', {
                        style: 'currency',
                        currency: 'IDR',
                        minimumFractionDigits: 0
                    }).format(data.todaySales || 0);
                }
                
                const todayTransactionCountEl = document.getElementById('todayTransactionCount');
                if (todayTransactionCountEl) {
                    todayTransactionCountEl.textContent = `${data.todayTransactionCount || 0} transaksi`;
                }
                
                // Total Products
                const totalProductsEl = document.getElementById('totalProducts');
                if (totalProductsEl) {
                    totalProductsEl.textContent = (data.totalProducts || 0).toLocaleString('id-ID');
                }
                
                const totalStockEl = document.getElementById('totalStock');
                if (totalStockEl) {
                    totalStockEl.textContent = `${(data.totalStock || 0).toLocaleString('id-ID')} stok total`;
                }
                
                // Low Stock
                const lowStockEl = document.getElementById('lowStock');
                if (lowStockEl) {
                    lowStockEl.textContent = (data.lowStockCount || 0).toLocaleString('id-ID');
                }
                
                // Total Customers
                const totalCustomersEl = document.getElementById('totalCustomers');
                if (totalCustomersEl) {
                    totalCustomersEl.textContent = (data.totalCustomers || 0).toLocaleString('id-ID');
                }
            }

            updateSalesChart(salesData) {
                const ctx = document.getElementById('salesChart');
                if (!ctx) return;

                try {
                    if (this.chartInstance) {
                        this.chartInstance.destroy();
                        }

                    this.chartInstance = new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: salesData.map(item => item.formatted_date || this.formatDate(item.date)),
                            datasets: [{
                                label: 'Penjualan (Rp)',
                                data: salesData.map(item => parseFloat(item.daily_sales) || 0),
                                borderColor: '#4e73df',
                                backgroundColor: 'rgba(78, 115, 223, 0.1)',
                                borderWidth: 2,
                                fill: true,
                                tension: 0.4,
                                pointBackgroundColor: '#4e73df',
                                pointBorderColor: '#fff',
                                pointHoverBackgroundColor: '#fff',
                                pointHoverBorderColor: '#4e73df',
                            }, {
                                label: 'Jumlah Transaksi',
                                data: salesData.map(item => parseInt(item.transaction_count) || 0),
                                borderColor: '#1cc88a',
                                backgroundColor: 'rgba(28, 200, 138, 0.1)',
                                borderWidth: 2,
                                fill: false,
                                tension: 0.4,
                                yAxisID: 'y1',
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            interaction: {
                                intersect: false,
                                mode: 'index'
                            },
                            plugins: {
                                legend: {
                                    display: true,
                                    position: 'top',
                                },
                                tooltip: {
                                    callbacks: {
                                        label: function(context) {
                                            if (context.datasetIndex === 0) {
                                                return 'Penjualan: ' + new Intl.NumberFormat('id-ID', {
                                                    style: 'currency',
                                                    currency: 'IDR',
                                                    minimumFractionDigits: 0
                                                }).format(context.raw);
                                            } else {
                                                return 'Transaksi: ' + context.raw + ' kali';
                                            }
                                        }
                                    }
                                }
                            },
                            scales: {
                                y: {
                                    type: 'linear',
                                    display: true,
                                    position: 'left',
                                    beginAtZero: true,
                                    ticks: {
                                        callback: function(value) {
                                            return new Intl.NumberFormat('id-ID', {
                                                style: 'currency',
                                                currency: 'IDR',
                                                minimumFractionDigits: 0,
                                                notation: 'compact'
                                            }).format(value);
                                        }
                                    }
                                },
                                y1: {
                                    type: 'linear',
                                    display: true,
                                    position: 'right',
                                    beginAtZero: true,
                                    grid: {
                                        drawOnChartArea: false,
                                    },
                                },
                            }
                        }
                    });
                } catch (error) {
                    console.error('Error updating chart:', error);
                    this.showToast('Gagal memperbarui grafik', 'error');
                }
            }
            
refreshChart() {
    const chartOverlay = document.getElementById('chartLoadingOverlay');
    const chartError = document.getElementById('chartErrorState');
    
    if (chartOverlay) {
        chartOverlay.style.display = 'flex';
    }
    
    if (chartError) {
        chartError.style.display = 'none';
    }
    
    // Simulasi loading chart data
    fetch('/api/dashboard/chart', {
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => {
        if (!response.ok) {
            throw new Error(`HTTP ${response.status}: ${response.statusText}`);
        }
        return response.json();
    })
    .then(result => {
        if (result.success) {
            this.updateSalesChart(result.data.salesChart);
            this.showToast('Grafik berhasil diperbarui', 'success');
        } else {
            throw new Error(result.message || 'Failed to refresh chart');
        }
    })
    .catch(error => {
        console.error('Error refreshing chart:', error);
        
        if (chartError) {
            chartError.style.display = 'flex';
        }
        
        this.showToast('Gagal memperbarui grafik', 'error');
    })
    .finally(() => {
        if (chartOverlay) {
            chartOverlay.style.display = 'none';
        }
        
        // Update chart last update time
        const chartLastUpdate = document.getElementById('chartLastUpdate');
        if (chartLastUpdate) {
            chartLastUpdate.textContent = `Diperbarui: ${new Date().toLocaleString('id-ID')}`;
        }
    });
}

            updateTopProducts(products) {
                const container = document.getElementById('topProducts');
                if (!container) return;

                if (!products || products.length === 0) {
                    container.innerHTML = '<p class="text-muted text-center">Tidak ada data produk</p>';
                    return;
                }

                const html = products.map((product, index) => `
                    <div class="d-flex align-items-center justify-content-between mb-3 p-2 rounded ${index < 3 ? 'bg-light' : ''}">
                        <div class="d-flex align-items-center">
                            <div class="me-3">
                                <span class="badge ${index === 0 ? 'bg-warning' : index === 1 ? 'bg-secondary' : index === 2 ? 'bg-info' : 'bg-light text-dark'}">${index + 1}</span>
                            </div>
                            <div>
                                <h6 class="mb-0">${product.nama}</h6>
                                <small class="text-muted">${product.total_sold} terjual</small>
                            </div>
                        </div>
                        <div class="text-end">
                            <div class="text-success fw-bold">
                                ${new Intl.NumberFormat('id-ID', {
                                    style: 'currency',
                                    currency: 'IDR',
                                    minimumFractionDigits: 0
                                }).format(product.total_revenue || 0)}
                            </div>
                        </div>
                    </div>
                `).join('');

                container.innerHTML = html;
            }

            updateRecentTransactions(transactions) {
                const tbody = document.querySelector('#recentTransactions tbody');
                if (!tbody) return;

                if (!transactions || transactions.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted">Tidak ada transaksi hari ini</td></tr>';
                    return;
                }

                const html = transactions.map(transaction => `
                    <tr>
                        <td>
                            <a href="/transactions/${transaction.id}" class="text-decoration-none">
                                #${transaction.id}
                            </a>
                        </td>
                        <td>${transaction.customer_name || 'Walk-in Customer'}</td>
                        <td>
                            ${new Intl.NumberFormat('id-ID', {
                                style: 'currency',
                                currency: 'IDR',
                                minimumFractionDigits: 0
                            }).format(transaction.total_harga)}
                        </td>
                        <td>
                            <span class="badge ${this.getStatusBadgeClass(transaction.status)}">
                                ${this.getStatusText(transaction.status)}
                            </span>
                        </td>
                        <td>
                            <small class="text-muted">
                                ${this.formatDateTime(transaction.tanggal_transaksi)}
                            </small>
                        </td>
                    </tr>
                `).join('');

                tbody.innerHTML = html;
            }

            updateLowStockItems(items) {
                const tbody = document.querySelector('#lowStockItems tbody');
                if (!tbody) return;

                if (!items || items.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted">Semua stok aman</td></tr>';
                    return;
                }

                const html = items.map(item => `
                    <tr>
                        <td>
                            <a href="/barangs/${item.id}" class="text-decoration-none">
                                ${item.nama}
                            </a>
                        </td>
                        <td><code>${item.SKU}</code></td>
                        <td>
                            <span class="badge ${item.jumlah_stok <= 5 ? 'bg-danger' : 'bg-warning'}">
                                ${item.jumlah_stok}
                            </span>
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a href="/barangs/${item.id}/edit" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="/pembelian/create?product_id=${item.id}" class="btn btn-outline-success btn-sm">
                                    <i class="bi bi-plus"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                `).join('');

                tbody.innerHTML = html;
            }

            updateLastUpdateTime(timestamp) {
                const element = document.getElementById('lastUpdate');
                if (element && timestamp) {
                    element.textContent = this.formatDateTime(timestamp);
                }
            }

            updateSystemTime() {
                const updateTime = () => {
                    const now = new Date();
                    const timeString = now.toLocaleString('id-ID', {
                        weekday: 'long',
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric',
                        hour: '2-digit',
                        minute: '2-digit',
                        second: '2-digit'
                    });
                    
                    const element = document.getElementById('currentDateTime');
                    if (element) {
                        element.textContent = timeString;
                    }
                };

                updateTime();
                setInterval(updateTime, 1000);
            }

            setupEventListeners() {
                // Refresh button
                const refreshBtn = document.getElementById('refreshBtn');
                if (refreshBtn) {
                    refreshBtn.addEventListener('click', () => this.loadInitialData());
                }

                // Keyboard shortcuts
                document.addEventListener('keydown', (e) => {
                    if (e.ctrlKey || e.metaKey) {
                        switch (e.key) {
                            case 'r':
                                e.preventDefault();
                                this.loadInitialData();
                                break;
                        }
                    }
                });

                // Window resize handler untuk chart
                window.addEventListener('resize', this.debounce(() => {
                    if (this.chartInstance) {
                        this.chartInstance.resize();
                    }
                }, 250));
            }

            setupAutoRefresh() {
                if (this.refreshTimer) {
                    clearInterval(this.refreshTimer);
                }
                
                this.refreshTimer = setInterval(() => {
                    if (!this.isLoading && document.visibilityState === 'visible') {
                        this.loadInitialData();
                    }
                }, this.config.refreshInterval);
                
                document.addEventListener('visibilitychange', () => {
                    if (document.visibilityState === 'visible' && !this.isLoading) {
                        this.loadInitialData();
                    }
                });
            }

            monitorConnectionStatus() {
                const indicator = document.getElementById('connectionIndicator');
                if (!indicator) return;

                const updateConnectionStatus = () => {
                    if (navigator.onLine) {
                        indicator.className = 'connection-status online';
                        indicator.innerHTML = '<i class="bi bi-wifi"></i> Online';
                    } else {
                        indicator.className = 'connection-status offline';
                        indicator.innerHTML = '<i class="bi bi-wifi-off"></i> Offline';
                    }
                };

                window.addEventListener('online', updateConnectionStatus);
                window.addEventListener('offline', updateConnectionStatus);
                updateConnectionStatus();
            }

            loadFallbackData() {
                const fallbackData = {
                    todaySales: 0,
                    todayTransactionCount: 0,
                    totalProducts: 0,
                    totalStock: 0,
                    lowStockCount: 0,
                    totalCustomers: 0,
                    recentTransactions: [],
                    lowStockItems: [],
                    topProducts: [],
                    salesChart: [],
                    lastUpdated: new Date().toISOString()
                };

                this.updateDashboard(fallbackData);
                this.showToast('Menggunakan data fallback', 'warning');
            }

            exportDashboard() {
                if (!confirm('Export data dashboard ke Excel?')) return;

                const exportBtn = document.querySelector('[onclick="dashboardPOS.exportDashboard()"]');
                if (exportBtn) {
                    exportBtn.disabled = true;
                    exportBtn.textContent = 'Exporting...';
                }

                fetch('/api/dashboard/export', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => {
                    if (!response.ok) throw new Error('Export failed');
                    return response.blob();
                })
                .then(blob => {
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `dashboard-report-${new Date().toISOString().split('T')[0]}.xlsx`;
                    document.body.appendChild(a);
                    a.click();
                    window.URL.revokeObjectURL(url);
                    document.body.removeChild(a);
                    
                    this.showToast('Dashboard berhasil diekspor', 'success');
                })
                .catch(error => {
                    console.error('Export error:', error);
                    this.showToast('Gagal mengekspor dashboard', 'error');
                })
                .finally(() => {
                    if (exportBtn) {
                        exportBtn.disabled = false;
                        exportBtn.textContent = 'Export Data';
                    }
                });
            }

            showToast(message, type = 'info', duration = 5000) {
                // Remove existing toasts of the same type
                document.querySelectorAll(`.toast-${type}`).forEach(toast => toast.remove());
                
                const toastContainer = document.getElementById('toastContainer') || document.body;
                const toast = document.createElement('div');
                toast.className = `alert alert-${type === 'error' ? 'danger' : type} alert-dismissible fade show toast-${type}`;
                toast.style.cssText = 'min-width: 300px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); margin-bottom: 10px;';
                
                const icon = {
                    success: '✓',
                    error: '✗',
                    warning: '⚠',
                    info: 'ℹ'
                }[type] || 'ℹ';
                
                toast.innerHTML = `
                    <div class="d-flex align-items-center">
                        <span class="me-2">${icon}</span>
                        <span>${message}</span>
                        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                    </div>
                `;
                
                toastContainer.appendChild(toast);
                
                setTimeout(() => {
                    if (toast.parentNode) {
                        toast.classList.remove('show');
                        setTimeout(() => toast.remove(), 150);
                    }
                }, duration);
            }

            // Utility methods
            formatDateTime(dateString) {
                if (!dateString) return '-';
                const date = new Date(dateString);
                return date.toLocaleString('id-ID', {
                    day: '2-digit',
                    month: '2-digit',
                    year: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                });
            }

            formatDate(dateString) {
                if (!dateString) return '-';
                const date = new Date(dateString);
                return date.toLocaleDateString('id-ID', {
                    day: '2-digit',
                    month: '2-digit'
                });
            }

            getStatusBadgeClass(status) {
                const statusClasses = {
                    'selesai': 'bg-success',
                    'pending': 'bg-warning',
                    'dibatalkan': 'bg-danger',
                    'draft': 'bg-secondary'
                };
                return statusClasses[status] || 'bg-secondary';
            }

            getStatusText(status) {
                const statusTexts = {
                    'selesai': 'Selesai',
                    'pending': 'Pending',
                    'dibatalkan': 'Dibatalkan',
                    'draft': 'Draft'
                };
                return statusTexts[status] || status;
            }

            debounce(func, wait) {
                let timeout;
                return function executedFunction(...args) {
                    const later = () => {
                        clearTimeout(timeout);
                        func(...args);
                    };
                    clearTimeout(timeout);
                    timeout = setTimeout(later, wait);
                };
            }

            cleanup() {
                if (this.refreshTimer) {
                    clearInterval(this.refreshTimer);
                }
                
                if (this.chartInstance) {
                    this.chartInstance.destroy();
                    this.chartInstance = null;
                }
                
                if (this.abortController) {
                    this.abortController.abort();
                }
            }
        }

        // Initialize dashboard when DOM is loaded
        let dashboardPOS;
        
        document.addEventListener('DOMContentLoaded', function() {
            dashboardPOS = new DashboardPOS({
                refreshInterval: 5 * 60 * 1000, // 5 minutes
                lowStockThreshold: 15,
                maxRetries: 3,
                retryDelay: 2000
            });

            // Global error handler
            window.addEventListener('error', (e) => {
                console.error('Global error:', e.error);
                if (dashboardPOS) {
                    dashboardPOS.showToast('Terjadi kesalahan sistem', 'error');
                }
            });

            // Unhandled promise rejection handler
            window.addEventListener('unhandledrejection', (e) => {
                console.error('Unhandled promise rejection:', e.reason);
                if (dashboardPOS) {
                    dashboardPOS.showToast('Terjadi kesalahan jaringan', 'error');
                }
            });
        });

        // Cleanup on page unload
        window.addEventListener('beforeunload', () => {
            if (dashboardPOS) {
                dashboardPOS.cleanup();
            }
        });

        // Add spinner animation
        const style = document.createElement('style');
        style.textContent = `
            @keyframes spin {
                0% { transform: rotate(0deg); }
                100% { transform: rotate(360deg); }
            }
            .spin { animation: spin 1s linear infinite; }
        `;
        document.head.appendChild(style);
    </script>
{% endblock %}
