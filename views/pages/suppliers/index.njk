{% extends "layout/masterLayout.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <h1 class="page-title">Manajemen Supplier</h1>
    <p class="page-subtitle">Kelola data pemasok dan vendor</p>
  </div>
  <div class="d-flex gap-2 flex-wrap">
    <a href="/suppliers/download" class="btn btn-outline-secondary btn-sm"><i class="fas fa-file-excel"></i> Export</a>
    <button class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#uploadModal"><i class="fas fa-upload"></i> Import</button>
    <button class="btn btn-outline-secondary btn-sm" id="btnDownloadTemplate"><i class="fas fa-download"></i> Template</button>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#tambahModal"><i class="fas fa-plus"></i> Tambah Supplier</button>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h6 class="card-header-title"><i class="fas fa-building"></i> Daftar Supplier</h6>
  </div>
  <div class="card-body">
    <div class="table-responsive">
      <table id="datatablesSimple" class="table">
        <thead>
          <tr><th>ID</th><th>Nama</th><th>Email</th><th>Telepon</th><th>Alamat</th><th>Aksi</th></tr>
        </thead>
        <tbody>
          {% for s in supplierst %}
          <tr>
            <td style="color:var(--text-3);font-size:.75rem;">{{ s.id }}</td>
            <td style="font-weight:500;">{{ s.nama }}</td>
            <td style="color:var(--text-2);">{{ s.email or '—' }}</td>
            <td style="font-family:'DM Mono',monospace;font-size:.775rem;">{{ s.telepon or '—' }}</td>
            <td style="color:var(--text-2);font-size:.8rem;">{{ s.alamat or '—' }}</td>
            <td>
              <div class="d-flex gap-1">
                <button class="btn btn-outline-secondary btn-sm btn-edit"
                  data-bs-toggle="modal" data-bs-target="#editModal"
                  data-id="{{ s.id }}" data-nama="{{ s.nama }}"
                  data-email="{{ s.email }}" data-telepon="{{ s.telepon }}" data-alamat="{{ s.alamat }}">
                  <i class="fas fa-pencil-alt"></i>
                </button>
                <button class="btn btn-outline-danger btn-sm delete-btn" data-id="{{ s.id }}" data-nama="{{ s.nama }}">
                  <i class="fas fa-trash-alt"></i>
                </button>
              </div>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Modal Upload -->
<div class="modal fade" id="uploadModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header">
      <h5 class="modal-title"><i class="fas fa-upload" style="color:var(--accent)"></i> Import Supplier</h5>
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <form enctype="multipart/form-data" method="post" action="/suppliers/upload">
      <div class="modal-body">
        <div class="alert alert-info"><i class="fas fa-info-circle flex-shrink-0"></i><span>File Excel (.xlsx/.xls). Download template untuk format yang benar.</span></div>
        <label class="form-label">Pilih file Excel</label>
        <input type="file" class="form-control" name="fileUpload" accept=".xls,.xlsx" required>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Batal</button>
        <button type="submit" class="btn btn-primary"><i class="fas fa-upload"></i> Upload</button>
      </div>
    </form>
  </div></div>
</div>

<!-- Modal Tambah -->
<div class="modal fade" id="tambahModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header">
      <h5 class="modal-title"><i class="fas fa-plus" style="color:var(--success)"></i> Tambah Supplier</h5>
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <form method="POST" action="/suppliers/tambah">
      <div class="modal-body">
        <div class="row g-3">
          <div class="col-12"><label class="form-label">Nama <span style="color:var(--danger)">*</span></label><input type="text" class="form-control" name="nama" required></div>
          <div class="col-md-6"><label class="form-label">Email</label><input type="email" class="form-control" name="email"></div>
          <div class="col-md-6"><label class="form-label">Telepon</label><input type="text" class="form-control" name="telepon"></div>
          <div class="col-12"><label class="form-label">Alamat</label><textarea class="form-control" name="alamat" rows="2"></textarea></div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Batal</button>
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Simpan</button>
      </div>
    </form>
  </div></div>
</div>

<!-- Modal Edit -->
<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header">
      <h5 class="modal-title"><i class="fas fa-pencil-alt" style="color:var(--accent)"></i> Edit Supplier</h5>
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <form method="POST" action="/suppliers/update">
      <div class="modal-body">
        <input type="hidden" id="editId" name="id">
        <div class="row g-3">
          <div class="col-12"><label class="form-label">Nama <span style="color:var(--danger)">*</span></label><input type="text" class="form-control" id="editNama" name="nama" required></div>
          <div class="col-md-6"><label class="form-label">Email</label><input type="email" class="form-control" id="editEmail" name="email"></div>
          <div class="col-md-6"><label class="form-label">Telepon</label><input type="text" class="form-control" id="editTelepon" name="telepon"></div>
          <div class="col-12"><label class="form-label">Alamat</label><textarea class="form-control" id="editAlamat" name="alamat" rows="2"></textarea></div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Batal</button>
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Simpan Perubahan</button>
      </div>
    </form>
  </div></div>
</div>

<!-- Modal Hapus -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-sm"><div class="modal-content">
    <div class="modal-header">
      <h5 class="modal-title"><i class="fas fa-exclamation-triangle" style="color:var(--danger)"></i> Hapus Supplier</h5>
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <div class="modal-body text-center" style="padding:1.5rem;">
      <p style="color:var(--text-2);font-size:.875rem;">Yakin ingin menghapus</p>
      <p style="font-weight:600;color:var(--danger);" id="deleteItemName"></p>
    </div>
    <div class="modal-footer">
      <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Batal</button>
      <form id="deleteForm" method="POST" class="d-inline">
        <button type="submit" class="btn btn-danger"><i class="fas fa-trash-alt"></i> Hapus</button>
      </form>
    </div>
  </div></div>
</div>
{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
  if (typeof simpleDatatables !== 'undefined') new simpleDatatables.DataTable('#datatablesSimple');
  document.querySelectorAll('.btn-edit').forEach(btn => {
    btn.addEventListener('click', function() {
      document.getElementById('editId').value      = this.dataset.id;
      document.getElementById('editNama').value    = this.dataset.nama;
      document.getElementById('editEmail').value   = this.dataset.email;
      document.getElementById('editTelepon').value = this.dataset.telepon;
      document.getElementById('editAlamat').value  = this.dataset.alamat;
    });
  });
  document.querySelectorAll('.delete-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      document.getElementById('deleteItemName').textContent = this.dataset.nama;
      document.getElementById('deleteForm').action = '/suppliers/hapus/' + this.dataset.id;
      new bootstrap.Modal(document.getElementById('deleteModal')).show();
    });
  });
  document.getElementById('btnDownloadTemplate')?.addEventListener('click', () => window.location.href = '/suppliers/template');
});
</script>
{% endblock %}
