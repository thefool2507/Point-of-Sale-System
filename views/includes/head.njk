<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <meta name="description" content="Funcode POS System" />
  <title>Funcode — POS</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/simple-datatables@7.1.2/dist/style.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css" rel="stylesheet">

  <link href="/css/styles.css" rel="stylesheet" />
  <link href="/css/dataTables.css" rel="stylesheet" />

  <style>
    /* ─── Design Tokens ─────────────────────────────── */
    :root {
      --sidebar-w: 260px;
      --topnav-h: 58px;

      --sidebar-bg:    #0F172A;
      --sidebar-hover: #1E293B;
      --sidebar-active:#1D4ED8;
      --sidebar-text:  #94A3B8;
      --sidebar-text-active: #F1F5F9;
      --sidebar-border:#1E293B;
      --sidebar-group: #475569;

      --topnav-bg:     #FFFFFF;
      --topnav-border: #E2E8F0;

      --bg:            #F1F5F9;
      --surface:       #FFFFFF;
      --surface-2:     #F8FAFC;
      --border:        #E2E8F0;
      --border-focus:  #3B82F6;

      --text-1:        #0F172A;
      --text-2:        #475569;
      --text-3:        #94A3B8;

      --accent:        #2563EB;
      --accent-hover:  #1D4ED8;
      --accent-light:  #EFF6FF;

      --success:       #059669;
      --success-light: #ECFDF5;
      --warning:       #D97706;
      --warning-light: #FFFBEB;
      --danger:        #DC2626;
      --danger-light:  #FEF2F2;
      --info:          #0891B2;
      --info-light:    #ECFEFF;

      --radius-sm:  6px;
      --radius:     8px;
      --radius-lg:  12px;
      --shadow-sm:  0 1px 2px rgba(0,0,0,.05);
      --shadow:     0 1px 3px rgba(0,0,0,.08), 0 1px 2px rgba(0,0,0,.06);
      --shadow-md:  0 4px 6px -1px rgba(0,0,0,.07), 0 2px 4px -1px rgba(0,0,0,.06);
    }

    /* ─── Base ──────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; }

    body {
      font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--text-1);
      font-size: 14px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    code, .font-mono, .sku-badge { font-family: 'DM Mono', monospace; }

    /* ─── Layout ─────────────────────────────────────── */
    #layoutSidenav { display: flex; min-height: calc(100vh - var(--topnav-h)); }

    #layoutSidenav_nav {
      width: var(--sidebar-w);
      flex-shrink: 0;
      position: fixed;
      top: var(--topnav-h);
      bottom: 0;
      left: 0;
      overflow-y: auto;
      overflow-x: hidden;
      z-index: 1030;
      background: var(--sidebar-bg);
      border-right: 1px solid var(--sidebar-border);
      scrollbar-width: thin;
      scrollbar-color: #1E293B transparent;
    }
    #layoutSidenav_nav::-webkit-scrollbar { width: 4px; }
    #layoutSidenav_nav::-webkit-scrollbar-thumb { background: #1E293B; }

    #layoutSidenav_content {
      flex: 1;
      margin-left: var(--sidebar-w);
      min-width: 0;
      display: flex;
      flex-direction: column;
    }

    main { flex: 1; padding: 1.5rem 1.75rem; }

    /* ─── Topnav ─────────────────────────────────────── */
    .sb-topnav {
      position: fixed !important;
      top: 0; left: 0; right: 0;
      height: var(--topnav-h);
      z-index: 1040;
      background: var(--topnav-bg) !important;
      border-bottom: 1px solid var(--topnav-border);
      box-shadow: var(--shadow-sm);
      display: flex;
      align-items: center;
      padding: 0 1.25rem;
    }

    .sb-nav-fixed body { padding-top: var(--topnav-h); }
    body.sb-nav-fixed #layoutSidenav { margin-top: var(--topnav-h); }

    .navbar-brand {
      font-size: 1.1rem;
      font-weight: 700;
      letter-spacing: -.3px;
      color: var(--text-1) !important;
    }

    #sidebarToggle {
      color: var(--text-2);
      background: none;
      border: none;
      padding: 0.375rem;
      border-radius: var(--radius-sm);
      cursor: pointer;
      transition: background .15s;
    }
    #sidebarToggle:hover { background: var(--bg); color: var(--text-1); }

    .nav-user-btn {
      display: flex; align-items: center; gap: .5rem;
      padding: .35rem .6rem;
      border-radius: var(--radius-sm);
      color: var(--text-2) !important;
      text-decoration: none;
      transition: background .15s, color .15s;
      font-size: .875rem;
    }
    .nav-user-btn:hover { background: var(--bg); color: var(--text-1) !important; }
    .nav-user-avatar {
      width: 30px; height: 30px;
      background: var(--accent);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      color: #fff;
      font-weight: 600;
      font-size: .75rem;
      flex-shrink: 0;
    }

    .dropdown-menu {
      border: 1px solid var(--border);
      box-shadow: var(--shadow-md);
      border-radius: var(--radius);
      padding: .375rem;
      min-width: 180px;
    }
    .dropdown-item {
      border-radius: var(--radius-sm);
      padding: .45rem .75rem;
      font-size: .875rem;
      color: var(--text-1);
      display: flex; align-items: center; gap: .5rem;
    }
    .dropdown-item:hover { background: var(--bg); color: var(--text-1); }
    .dropdown-item.text-danger:hover { background: var(--danger-light); color: var(--danger); }
    .dropdown-divider { border-color: var(--border); margin: .25rem 0; }

    /* ─── Sidebar ────────────────────────────────────── */
    .sb-sidenav { background: var(--sidebar-bg); height: 100%; display: flex; flex-direction: column; }
    .sb-sidenav-menu { flex: 1; padding: 1rem 0 .5rem; }
    .sb-sidenav-menu .nav { flex-direction: column; gap: 1px; padding: 0 .625rem; }

    /* section label */
    .sb-nav-label {
      text-transform: uppercase;
      letter-spacing: .08em;
      font-size: .65rem;
      font-weight: 600;
      color: var(--sidebar-group);
      padding: 1.25rem .75rem .35rem;
      white-space: nowrap;
    }

    .nav-link {
      display: flex;
      align-items: center;
      gap: .625rem;
      padding: .5rem .75rem;
      border-radius: var(--radius-sm);
      color: var(--sidebar-text);
      font-size: .825rem;
      font-weight: 400;
      text-decoration: none;
      transition: background .15s, color .15s;
      white-space: nowrap;
      line-height: 1.4;
    }
    .nav-link:hover { background: var(--sidebar-hover); color: var(--sidebar-text-active); }
    .nav-link.active, .nav-link[aria-current="page"] {
      background: var(--sidebar-active);
      color: #fff;
      font-weight: 500;
    }

    .sb-nav-link-icon {
      width: 18px; text-align: center; flex-shrink: 0;
      font-size: .8rem;
    }

    .sb-sidenav-collapse-arrow {
      margin-left: auto;
      font-size: .625rem;
      opacity: .6;
      transition: transform .2s;
    }
    .nav-link[aria-expanded="true"] .sb-sidenav-collapse-arrow {
      transform: rotate(180deg); opacity: 1;
    }

    .sb-sidenav-menu-nested {
      padding: .125rem 0 .25rem 1rem;
      display: flex; flex-direction: column; gap: 1px;
    }
    .sb-sidenav-menu-nested .nav-link {
      font-size: .8rem;
      padding: .375rem .75rem;
      color: #64748B;
    }
    .sb-sidenav-menu-nested .nav-link:hover { color: var(--sidebar-text-active); }

    .sb-sidenav-footer {
      padding: .875rem 1rem;
      border-top: 1px solid var(--sidebar-border);
      font-size: .75rem;
    }
    .sb-sidenav-footer .small { color: var(--sidebar-group); margin-bottom: .15rem; }
    .sb-sidenav-footer .fw-bold { color: var(--sidebar-text-active); font-size: .8rem; }

    /* ─── Page Header ───────────────────────────────── */
    .page-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: .75rem;
      margin-bottom: 1.5rem;
    }
    .page-title {
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--text-1);
      letter-spacing: -.3px;
      margin: 0;
    }
    .page-subtitle {
      font-size: .8rem;
      color: var(--text-3);
      margin: .1rem 0 0;
    }

    /* ─── Cards ─────────────────────────────────────── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-sm);
      transition: box-shadow .2s;
    }
    .card:hover { box-shadow: var(--shadow); }

    .card-header {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      border-radius: var(--radius-lg) var(--radius-lg) 0 0 !important;
      padding: .875rem 1.125rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: .5rem;
    }
    .card-header-title {
      font-size: .875rem;
      font-weight: 600;
      color: var(--text-1);
      margin: 0;
      display: flex; align-items: center; gap: .5rem;
    }
    .card-header-title i { color: var(--text-3); font-size: .8rem; }

    .card-body { padding: 1.125rem; }
    .card-footer {
      background: var(--surface-2);
      border-top: 1px solid var(--border);
      border-radius: 0 0 var(--radius-lg) var(--radius-lg) !important;
      padding: .75rem 1.125rem;
    }

    /* Stat Cards */
    .stat-card { position: relative; overflow: hidden; }
    .stat-card .stat-icon {
      position: absolute; top: 1rem; right: 1rem;
      width: 42px; height: 42px;
      border-radius: var(--radius);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem;
    }
    .stat-card .stat-value {
      font-size: 1.6rem;
      font-weight: 700;
      letter-spacing: -.5px;
      color: var(--text-1);
      line-height: 1;
      margin-bottom: .25rem;
    }
    .stat-card .stat-label {
      font-size: .75rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: .05em;
      color: var(--text-3);
    }
    .stat-card .stat-sub {
      font-size: .75rem;
      color: var(--text-2);
      margin-top: .35rem;
    }

    .stat-accent-blue  .stat-icon { background: var(--accent-light); color: var(--accent); }
    .stat-accent-green .stat-icon { background: var(--success-light); color: var(--success); }
    .stat-accent-amber .stat-icon { background: var(--warning-light); color: var(--warning); }
    .stat-accent-red   .stat-icon { background: var(--danger-light);  color: var(--danger);  }
    .stat-accent-cyan  .stat-icon { background: var(--info-light);    color: var(--info);    }

    /* ─── Buttons ───────────────────────────────────── */
    .btn {
      font-weight: 500;
      font-size: .8125rem;
      border-radius: var(--radius-sm);
      padding: .45rem 1rem;
      display: inline-flex; align-items: center; gap: .375rem;
      transition: all .15s;
      letter-spacing: .01em;
      border: 1px solid transparent;
    }
    .btn-sm { padding: .3rem .75rem; font-size: .775rem; }
    .btn-lg { padding: .625rem 1.375rem; font-size: .875rem; }

    .btn-primary {
      background: var(--accent); border-color: var(--accent); color: #fff;
    }
    .btn-primary:hover { background: var(--accent-hover); border-color: var(--accent-hover); color: #fff; }

    .btn-success { background: var(--success); border-color: var(--success); color: #fff; }
    .btn-success:hover { background: #047857; border-color: #047857; color: #fff; }

    .btn-warning { background: var(--warning); border-color: var(--warning); color: #fff; }
    .btn-warning:hover { background: #B45309; border-color: #B45309; color: #fff; }

    .btn-danger { background: var(--danger); border-color: var(--danger); color: #fff; }
    .btn-danger:hover { background: #B91C1C; border-color: #B91C1C; color: #fff; }

    .btn-info { background: var(--info); border-color: var(--info); color: #fff; }
    .btn-info:hover { background: #0E7490; border-color: #0E7490; color: #fff; }

    .btn-secondary { background: #64748B; border-color: #64748B; color: #fff; }
    .btn-secondary:hover { background: #475569; border-color: #475569; color: #fff; }

    .btn-outline-primary { background: transparent; border-color: var(--accent); color: var(--accent); }
    .btn-outline-primary:hover { background: var(--accent); color: #fff; }

    .btn-outline-danger { background: transparent; border-color: var(--danger); color: var(--danger); }
    .btn-outline-danger:hover { background: var(--danger); color: #fff; }

    .btn-outline-secondary { background: transparent; border-color: var(--border); color: var(--text-2); }
    .btn-outline-secondary:hover { background: var(--bg); color: var(--text-1); border-color: #CBD5E1; }

    .btn-ghost { background: transparent; border-color: transparent; color: var(--text-2); }
    .btn-ghost:hover { background: var(--bg); color: var(--text-1); }

    /* ─── Forms ─────────────────────────────────────── */
    .form-control, .form-select {
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      font-size: .8125rem;
      color: var(--text-1);
      background: var(--surface);
      padding: .475rem .75rem;
      transition: border-color .15s, box-shadow .15s;
    }
    .form-control:focus, .form-select:focus {
      border-color: var(--border-focus);
      box-shadow: 0 0 0 3px rgba(59,130,246,.12);
      outline: none;
    }
    .form-control::placeholder { color: var(--text-3); }
    .form-label {
      font-size: .8rem;
      font-weight: 500;
      color: var(--text-2);
      margin-bottom: .35rem;
    }
    .form-text { font-size: .75rem; color: var(--text-3); }
    .input-group-text {
      background: var(--surface-2);
      border-color: var(--border);
      color: var(--text-2);
      font-size: .8125rem;
    }
    .form-floating > .form-control:focus ~ label,
    .form-floating > .form-control:not(:placeholder-shown) ~ label { color: var(--accent); }

    /* ─── Tables ────────────────────────────────────── */
    .table {
      font-size: .8125rem;
      color: var(--text-1);
      margin-bottom: 0;
    }
    .table th {
      font-size: .7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: var(--text-3);
      border-bottom: 1px solid var(--border) !important;
      padding: .6rem 1rem;
      background: var(--surface-2);
      white-space: nowrap;
    }
    .table td {
      padding: .7rem 1rem;
      border-color: var(--border);
      vertical-align: middle;
    }
    .table tbody tr:hover { background: var(--surface-2); }
    .table-striped tbody tr:nth-of-type(odd) { background: rgba(241,245,249,.5); }
    .table-striped tbody tr:nth-of-type(odd):hover { background: var(--surface-2); }
    .table thead.table-dark th {
      background: var(--surface-2);
      color: var(--text-3);
    }

    /* ─── Badges ────────────────────────────────────── */
    .badge {
      font-size: .68rem;
      font-weight: 500;
      padding: .28em .6em;
      border-radius: 4px;
      letter-spacing: .02em;
    }
    .badge.bg-primary   { background: var(--accent-light)  !important; color: var(--accent)  !important; }
    .badge.bg-success   { background: var(--success-light) !important; color: var(--success) !important; }
    .badge.bg-warning   { background: var(--warning-light) !important; color: var(--warning) !important; }
    .badge.bg-danger    { background: var(--danger-light)  !important; color: var(--danger)  !important; }
    .badge.bg-info      { background: var(--info-light)    !important; color: var(--info)    !important; }
    .badge.bg-secondary { background: #F1F5F9 !important; color: #64748B !important; }
    .badge.bg-dark      { background: #1E293B !important; color: #F1F5F9 !important; }

    /* ─── Modals ────────────────────────────────────── */
    .modal-content {
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      box-shadow: 0 20px 60px rgba(0,0,0,.15);
    }
    .modal-header {
      padding: 1rem 1.25rem;
      border-bottom: 1px solid var(--border);
      align-items: center;
    }
    .modal-title {
      font-size: .9375rem;
      font-weight: 600;
      color: var(--text-1);
      display: flex; align-items: center; gap: .5rem;
    }
    .modal-body { padding: 1.25rem; }
    .modal-footer {
      padding: .875rem 1.25rem;
      border-top: 1px solid var(--border);
      gap: .5rem;
    }
    .btn-close { opacity: .5; }
    .btn-close:hover { opacity: 1; }

    /* ─── Alerts ────────────────────────────────────── */
    .alert {
      border-radius: var(--radius);
      font-size: .8125rem;
      padding: .7rem 1rem;
      border: 1px solid;
      display: flex; align-items: flex-start; gap: .625rem;
    }
    .alert-success { background: var(--success-light); border-color: #A7F3D0; color: #065F46; }
    .alert-danger  { background: var(--danger-light);  border-color: #FECACA; color: #991B1B; }
    .alert-warning { background: var(--warning-light); border-color: #FDE68A; color: #92400E; }
    .alert-info    { background: var(--info-light);    border-color: #A5F3FC; color: #164E63; }

    /* ─── Quick-action buttons ──────────────────────── */
    .quick-btn {
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: .5rem;
      padding: 1.125rem .75rem;
      border-radius: var(--radius);
      text-decoration: none;
      font-size: .775rem;
      font-weight: 500;
      color: var(--text-2);
      background: var(--surface);
      border: 1px solid var(--border);
      transition: all .15s;
      text-align: center;
    }
    .quick-btn:hover {
      border-color: var(--accent);
      color: var(--accent);
      box-shadow: var(--shadow);
      transform: translateY(-1px);
    }
    .quick-btn i { font-size: 1.25rem; }

    /* ─── Product/POS specific ──────────────────────── */
    .product-item {
      padding: .75rem;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      cursor: pointer;
      transition: all .15s;
      background: var(--surface);
      margin-bottom: .375rem;
    }
    .product-item:hover { border-color: var(--accent); background: var(--accent-light); }
    .product-item.selected { border-color: var(--accent); background: var(--accent-light); }

    .cart-item {
      padding: .7rem 0;
      border-bottom: 1px solid var(--border);
    }
    .cart-item:last-child { border-bottom: none; }

    .qty-btn {
      width: 26px; height: 26px;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      background: var(--surface);
      color: var(--text-2);
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      transition: all .15s;
      font-size: .75rem;
    }
    .qty-btn:hover { background: var(--accent); border-color: var(--accent); color: #fff; }

    .total-panel {
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1rem;
    }
    .total-panel .total-row {
      display: flex; justify-content: space-between;
      font-size: .8125rem;
      padding: .25rem 0;
      color: var(--text-2);
    }
    .total-panel .total-row.grand {
      font-size: 1rem;
      font-weight: 700;
      color: var(--text-1);
      padding-top: .5rem;
      border-top: 1px solid var(--border);
      margin-top: .25rem;
    }

    /* ─── Avatar ────────────────────────────────────── */
    .user-avatar {
      width: 32px; height: 32px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-weight: 600; font-size: .75rem; color: #fff;
      flex-shrink: 0;
    }
    .avatar-blue   { background: var(--accent); }
    .avatar-green  { background: var(--success); }
    .avatar-amber  { background: var(--warning); }

    /* ─── Footer ────────────────────────────────────── */
    footer {
      border-top: 1px solid var(--border);
      padding: .875rem 1.75rem;
      font-size: .75rem;
      color: var(--text-3);
    }

    /* ─── Responsive ────────────────────────────────── */
    @media (max-width: 768px) {
      #layoutSidenav_nav { transform: translateX(-100%); transition: transform .25s; }
      #layoutSidenav_nav.show { transform: translateX(0); }
      #layoutSidenav_content { margin-left: 0; }
      main { padding: 1rem; }
    }

    /* ─── Scrollbar ─────────────────────────────────── */
    ::-webkit-scrollbar { width: 5px; height: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #CBD5E1; border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: #94A3B8; }

    /* ─── Utilities ─────────────────────────────────── */
    .text-muted { color: var(--text-3) !important; }
